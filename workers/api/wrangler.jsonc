{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "se-plus-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-22",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "se-plus-study-context"
		}
	],
	"vars": {
		"ALLOWED_ORIGIN": "http://localhost:5173"
	}
}